{
  "expo": {
    "name": "CampusIQ",
    "slug": "campusiq",
    "version": "1.0.0",
    "scheme": "campusiq",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#1E40AF",
      "resizeMode": "contain",
      "image": "./assets/images/icon.png"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.campusiq.app"
    },
    "android": {
      "package": "com.campusiq.app",
      "adaptiveIcon": {
        "backgroundColor": "#1E40AF",
        "foregroundImage": "./assets/images/icon.png"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "CampusIQ uses the camera to scan campus QR codes and identify landmarks."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow CampusIQ to use your location to show your position on the map and provide navigation."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
