{
  "expo": {
    "name": "CampusWay AI",
    "slug": "campusway-ai",
    "version": "1.0.0",
    "scheme": "campusway",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#1E40AF",
      "resizeMode": "contain",
      "image": "./assets/images/icon.png"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.campusway.ai"
    },
    "android": {
      "package": "com.campusway.ai",
      "adaptiveIcon": {
        "backgroundColor": "#1E40AF",
        "foregroundImage": "./assets/images/icon.png"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
